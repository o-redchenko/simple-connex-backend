generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model base_item_modifier_categories {
  id                   Int                  @id @default(autoincrement())
  base_item_id         Int?
  modifier_category_id Int?
  created_at           DateTime?            @default(now()) @db.Timestamp(6)
  updated_at           DateTime?            @default(now()) @db.Timestamp(6)
  base_items           base_items?          @relation(fields: [base_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modifier_categories  modifier_categories? @relation(fields: [modifier_category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([base_item_id, modifier_category_id])
  @@index([base_item_id], map: "idx_base_item_mod_cats_base_item")
}

model base_item_variation_categories {
  id                    Int                   @id @default(autoincrement())
  base_item_id          Int?
  variation_category_id Int?
  created_at            DateTime?             @default(now()) @db.Timestamp(6)
  updated_at            DateTime?             @default(now()) @db.Timestamp(6)
  base_items            base_items?           @relation(fields: [base_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variation_categories  variation_categories? @relation(fields: [variation_category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([base_item_id, variation_category_id], map: "base_item_variation_categorie_base_item_id_variation_catego_key")
  @@index([base_item_id], map: "idx_base_item_var_cats_base_item")
}

model base_items {
  id                             Int                              @id @default(autoincrement())
  name                           String                           @db.VarChar(255)
  description                    String?
  base_price                     Decimal                          @db.Decimal(10, 2)
  base_image_url                 String?
  created_at                     DateTime?                        @default(now()) @db.Timestamp(6)
  updated_at                     DateTime?                        @default(now()) @db.Timestamp(6)
  base_item_modifier_categories  base_item_modifier_categories[]
  base_item_variation_categories base_item_variation_categories[]
  menu_items                     menu_items[]
}

model location_menus {
  id          Int       @id @default(autoincrement())
  location_id Int
  menu_id     Int
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  locations   locations @relation(fields: [location_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  menus       menus     @relation(fields: [menu_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([location_id, menu_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model locations {
  id                 Int              @id @default(autoincrement())
  name               String           @db.VarChar(255)
  address            String           @db.VarChar(255)
  city               String           @db.VarChar(100)
  phone              String?          @db.VarChar(20)
  is_active          Boolean?         @default(true)
  created_at         DateTime?        @default(now()) @db.Timestamp(6)
  updated_at         DateTime?        @default(now()) @db.Timestamp(6)
  hours_of_operation Json?
  show_in_app        Boolean?         @default(true)
  delivery_available Boolean?         @default(false)
  location_type      String?          @default("dine_in_and_takeout") @db.VarChar(50)
  image_url          String?
  images             Json?            @default("[]")
  location_menus     location_menus[]
  orders             orders[]
}

model menu_categories {
  id            Int          @id @default(autoincrement())
  menu_id       Int
  name          String       @db.VarChar(255)
  description   String?
  display_order Int?         @default(0)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  image_url     String?
  updated_at    DateTime?    @default(now()) @db.Timestamp(6)
  menus         menus        @relation(fields: [menu_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  menu_items    menu_items[]

  @@index([menu_id], map: "idx_menu_categories_menu")
}

model menu_item_modifiers {
  id            Int        @id @default(autoincrement())
  menu_item_id  Int
  modifier_id   Int
  price         Decimal    @db.Decimal(10, 2)
  max_quantity  Int?       @default(1)
  is_available  Boolean?   @default(true)
  display_order Int?       @default(0)
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  updated_at    DateTime?  @default(now()) @db.Timestamp(6)
  menu_items    menu_items @relation(fields: [menu_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modifiers     modifiers  @relation(fields: [modifier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([menu_item_id, modifier_id])
  @@index([menu_item_id], map: "idx_menu_item_modifiers_item")
}

model menu_item_variations {
  id               Int        @id @default(autoincrement())
  menu_item_id     Int
  variation_id     Int
  price_adjustment Decimal    @default(0) @db.Decimal(10, 2)
  is_default       Boolean?   @default(false)
  is_available     Boolean?   @default(true)
  display_order    Int?       @default(0)
  created_at       DateTime?  @default(now()) @db.Timestamp(6)
  updated_at       DateTime?  @default(now()) @db.Timestamp(6)
  menu_items       menu_items @relation(fields: [menu_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variations       variations @relation(fields: [variation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([menu_item_id, variation_id])
  @@index([menu_item_id], map: "idx_menu_item_variations_item")
}

model menu_items {
  id                     Int                    @id @default(autoincrement())
  menu_category_id       Int
  base_item_id           Int
  custom_name            String?                @db.VarChar(255)
  custom_description     String?
  custom_image_url       String?
  custom_price           Decimal?               @db.Decimal(10, 2)
  is_available           Boolean?               @default(true)
  max_quantity_per_order Int?                   @default(10)
  display_order          Int?                   @default(0)
  created_at             DateTime?              @default(now()) @db.Timestamp(6)
  updated_at             DateTime?              @default(now()) @db.Timestamp(6)
  menu_item_modifiers    menu_item_modifiers[]
  menu_item_variations   menu_item_variations[]
  base_items             base_items             @relation(fields: [base_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  menu_categories        menu_categories        @relation(fields: [menu_category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items            order_items[]

  @@index([base_item_id], map: "idx_menu_items_base")
  @@index([menu_category_id], map: "idx_menu_items_category")
}

model menus {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(255)
  description     String?
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  updated_at      DateTime?         @db.Timestamptz(6)
  location_menus  location_menus[]
  menu_categories menu_categories[]
}

model modifier_categories {
  id                            Int                             @id @default(autoincrement())
  name                          String                          @unique @db.VarChar(100)
  description                   String?
  display_order                 Int?                            @default(0)
  created_at                    DateTime?                       @default(now()) @db.Timestamp(6)
  updated_at                    DateTime?                       @default(now()) @db.Timestamp(6)
  base_item_modifier_categories base_item_modifier_categories[]
  modifiers                     modifiers[]
}

model modifiers {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @unique @db.VarChar(100)
  description          String?
  default_price        Decimal?               @default(0) @db.Decimal(10, 2)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  category_id          Int?
  display_order        Int?
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  menu_item_modifiers  menu_item_modifiers[]
  modifier_categories  modifier_categories?   @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  order_item_modifiers order_item_modifiers[]

  @@unique([name, category_id], map: "unique_modifier_name_category")
  @@index([category_id], map: "idx_modifiers_category")
}

model order_item_modifiers {
  id            Int         @id @default(autoincrement())
  order_item_id Int
  modifier_id   Int?
  modifier_name String      @db.VarChar(100)
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int?        @default(1)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  modifiers     modifiers?  @relation(fields: [modifier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order_items   order_items @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model order_item_variations {
  id               Int         @id @default(autoincrement())
  order_item_id    Int
  variation_id     Int?
  variation_name   String      @db.VarChar(100)
  price_adjustment Decimal     @db.Decimal(10, 2)
  created_at       DateTime?   @default(now()) @db.Timestamp(6)
  order_items      order_items @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variations       variations? @relation(fields: [variation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model order_items {
  id                    Int                     @id @default(autoincrement())
  order_id              Int
  menu_item_id          Int?
  item_name             String                  @db.VarChar(255)
  item_description      String?
  quantity              Int                     @default(1)
  base_price            Decimal                 @db.Decimal(10, 2)
  total_price           Decimal                 @db.Decimal(10, 2)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  order_item_modifiers  order_item_modifiers[]
  order_item_variations order_item_variations[]
  menu_items            menu_items?             @relation(fields: [menu_item_id], references: [id], onUpdate: NoAction)
  orders                orders                  @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order")
}

model orders {
  id           Int            @id @default(autoincrement())
  user_id      Int
  location_id  Int
  status       String?        @default("pending") @db.VarChar(50)
  total_amount Decimal        @db.Decimal(10, 2)
  notes        String?
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  order_items  order_items[]
  locations    locations      @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        users          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions transactions[]

  @@index([user_id], map: "idx_orders_user")
}

model transactions {
  id             Int       @id @default(autoincrement())
  user_id        Int
  order_id       Int?
  type           String    @db.VarChar(50)
  amount         Decimal   @db.Decimal(10, 2)
  balance_before Decimal   @db.Decimal(10, 2)
  balance_after  Decimal   @db.Decimal(10, 2)
  status         String?   @default("completed") @db.VarChar(50)
  payment_method String?   @db.VarChar(50)
  notes          String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  orders         orders?   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_transactions_user")
}

model users {
  id           Int            @id @default(autoincrement())
  email        String         @unique @db.VarChar(255)
  first_name   String?        @db.VarChar(100)
  last_name    String?        @db.VarChar(100)
  role         String?        @default("customer") @db.VarChar(50)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  password     String?        @db.VarChar(255)
  balance      Decimal?       @db.Decimal
  orders       orders[]
  transactions transactions[]
}

model variation_categories {
  id                             Int                              @id @default(autoincrement())
  name                           String                           @unique @db.VarChar(100)
  description                    String?
  display_order                  Int?                             @default(0)
  created_at                     DateTime?                        @default(now()) @db.Timestamp(6)
  updated_at                     DateTime?                        @default(now()) @db.Timestamp(6)
  base_item_variation_categories base_item_variation_categories[]
  variations                     variations[]
}

model variations {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @unique @db.VarChar(100)
  description           String?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  category_id           Int?
  display_order         Int?
  default_price         Decimal?                @db.Decimal
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  menu_item_variations  menu_item_variations[]
  order_item_variations order_item_variations[]
  variation_categories  variation_categories?   @relation(fields: [category_id], references: [id], onUpdate: NoAction)

  @@unique([name, category_id], map: "unique_variation_name_category")
  @@index([category_id], map: "idx_variations_category")
}
