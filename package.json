{
  "name": "simple-connex-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev:watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "create-admin": "node scripts/createAdmin.js",
    "seed": "node scripts/seedDatabase.js",
    "seed-full-orders": "node scripts/seed-full-orders.js",
    "generate": "node scripts/generateData.js",
    "clean": "node scripts/cleanDatabase.js",
    "extend-locations": "node scripts/extendLocations.js",
    "db:sync": "ts-node scripts/sync.js",
    "server": "npx ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "db:up": "docker-compose up -d",
    "dev": "concurrently \"npm run db:up\" \"wait-on tcp:5432 && npm run server\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.16.0",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.5"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 10000
  }
}
